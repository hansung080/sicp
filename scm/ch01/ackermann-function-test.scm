(test "ackermann-function"
      (lambda ()
        (assert-eq (A 1 10) 1024)
        (assert-eq (A 2 4) 65536)
        (assert-eq (A 3 3) 65536)))

(test "ackermann-function-f"
      (lambda ()
        (assert-eq (f 1) 2)
        (assert-eq (f 2) 4)
        (assert-eq (f 3) 6)
        (assert-eq (f 4) 8)))

(test "ackermann-function-g"
      (lambda ()
        (assert-eq (g 1) 2)
        (assert-eq (g 2) 4)
        (assert-eq (g 3) 8)
        (assert-eq (g 4) 16)))

(test "ackermann-function-h"
      (lambda ()
        (assert-eq (h 1) 2)
        (assert-eq (h 2) 4)
        (assert-eq (h 3) 16)
        (assert-eq (h 4) 65536)))
