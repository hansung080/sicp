(load "../common/testing.scm")

(define (A x y)
  (cond ((= y 0) 0)
        ((= x 0) (* 2 y))
        ((= y 1) 2)
        (else (A (- x 1)
                 (A x (- y 1))))))

;; f(n) = 2n
(define (f n)
  (A 0 n))

;; g(n) = 2^n
(define (g n)
  (A 1 n))

;; h(0) = 1
;; h(n) = 2^h(n-1)  (n >= 1)
;; (e.g. h(4) = 2^2^2^2 = 65536)
(define (h n)
  (A 2 n))

